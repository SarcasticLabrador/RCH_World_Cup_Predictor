# Streamlit Community Cloud secrets for the FRONTEND.
# In Streamlit Cloud: App > Settings > Secrets, paste the contents below (TOML).
# Locally, copy to .streamlit/secrets.toml (gitignored) or set BACKEND_URL as an env var.

# Public URL of the deployed FastAPI backend on Render (no trailing slash).
BACKEND_URL = "https://worldcup-predictor-api.onrender.com"
