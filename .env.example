# ----------------------------------------------------------------------------
# World Cup Predictor — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ----------------------------------------------------------------------------

# --- Core (Phase 1) ---
APP_NAME="FIFA World Cup 2026 Predictor"
ENVIRONMENT=development                 # development | production
# Path to the SQLite file. On Streamlit Cloud this points at the persistent volume.
DATABASE_URL=sqlite:///./data/worldcup.db

# --- Auth / Email (Phase 2) ---
# Public URL of the Streamlit app (used to build magic-link URLs).
APP_BASE_URL=http://localhost:8501
# Email provider: "console" (dev: logs link to server output) or "brevo".
EMAIL_PROVIDER=console
# Brevo transactional API key (only needed when EMAIL_PROVIDER=brevo).
BREVO_API_KEY=
# Your verified single-sender address + display name (Brevo single-sender).
EMAIL_FROM=
EMAIL_FROM_NAME="World Cup Predictor"
MAGIC_LINK_TTL_HOURS=24
SESSION_TTL_DAYS=30
# Comma-separated whitelist, e.g. "@yourcompany.com" or specific addresses.
EMAIL_WHITELIST=@yourcompany.com
# Comma-separated admin addresses (these users become admins on first login).
ADMIN_EMAILS=
# Secret used to sign session tokens (generate a long random string).
SECRET_KEY=change-me

# --- Results API (Phase 4) ---
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- Gemini AI (Phase 7) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Configurable model name (e.g. gemini-2.5-flash, or a newer one).
GEMINI_MODEL=gemini-2.5-flash

# --- Scheduler & tasks (Phase 6) ---
# In-process scheduler. Set to false on hosts that sleep and use /tasks/* via
# an external cron (e.g. GitHub Actions) instead.
SCHEDULER_ENABLED=true
RESULTS_POLL_MINUTES=120
SNAPSHOT_HOUR_CET=6
# Shared secret for /tasks/maintenance and /tasks/snapshot (external cron).
# Leave empty to disable those endpoints.
TASK_TOKEN=
